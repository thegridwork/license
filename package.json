{
  "name": "gridwork-license",
  "version": "1.0.0",
  "mcpName": "io.github.thegridwork/license",
  "description": "MCP server that scans project dependencies for license compliance — detects conflicts, copyleft risks, and undeclared licenses",
  "repository": {
    "type": "git",
    "url": "https://github.com/thegridwork/license.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "gridwork-license": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "license",
    "compliance",
    "open-source",
    "dependencies",
    "copyleft",
    "audit"
  ],
  "author": "Gridwork <thegridwork@proton.me>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
